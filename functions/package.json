{
    "name": "market-x-functions",
    "version": "1.0.0",
    "description": "Market_x Cloud Functions for Firebase",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log",
        "dev": "npm run build:watch"
    },
    "engines": {
        "node": "20"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "firebase-admin": "^13.6.1",
        "firebase-functions": "^6.3.2",
        "helmet": "^8.1.0",
        "stripe": "^14.25.0",
        "razorpay": "^2.9.6",
        "uuid": "^13.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^22.0.0",
        "@types/uuid": "^10.0.0",
        "typescript": "^5.9.3"
    }
}