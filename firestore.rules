rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }
    function isHero() {
      return isAuthenticated() && request.auth.token.role == 'hero';
    }
    function isShopkeeper() {
      return isAuthenticated() && request.auth.token.role == 'shopkeeper';
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    // ── Stores ────────────────────────────────────────────────
    match /stores/{storeId} {
      allow read: if true;  // public storefront
      allow create: if isAuthenticated();
      allow update: if isAdmin() || 
        (isShopkeeper() && resource.data.owner == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── Products ──────────────────────────────────────────────
    match /products/{productId} {
      allow read: if true;  // public catalog
      allow create, update: if isShopkeeper() || isAdmin();
      allow delete: if isShopkeeper() || isAdmin();
    }

    // ── Orders ────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Carts ─────────────────────────────────────────────────
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Deliveries ────────────────────────────────────────────
    match /deliveries/{deliveryId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
    }

    // ── Delivery Drivers ──────────────────────────────────────
    match /deliveryDrivers/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(driverId) || isAdmin();
    }

    // ── Driver Locations (real-time tracking) ─────────────────
    match /driverLocations/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(driverId);
    }

    // ── Delivery Tracking (real-time for customers) ───────────
    match /deliveryTracking/{trackingId} {
      allow read: if isAuthenticated();
      allow write: if isHero() || isAdmin();
    }

    // ── Disputes ──────────────────────────────────────────────
    match /disputes/{disputeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    // ── Hero Applications ─────────────────────────────────────
    match /heroApplications/{appId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }

    // ── Hero Ratings ──────────────────────────────────────────
    match /heroRatings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // ── Ledger Entries (immutable) ─────────────────────────────
    match /ledgerEntries/{entryId} {
      allow read: if isAuthenticated();
      // Only server (admin SDK) can write — no client writes
      allow write: if false;
    }

    // ── Admin Action Logs (immutable audit) ───────────────────
    match /adminActionLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // server-only
    }

    // ── Risk Flags ────────────────────────────────────────────
    match /riskFlags/{flagId} {
      allow read: if isAdmin();
      allow write: if false; // server-only
    }

    // ── Campus Config ─────────────────────────────────────────
    match /campusConfigs/{configId} {
      allow read: if true; // public
      allow write: if isAdmin();
    }

    // ── Campus POIs ───────────────────────────────────────────
    match /campusPOIs/{poiId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Webhook Events ────────────────────────────────────────
    match /webhookEvents/{eventId} {
      allow read, write: if false; // server-only
    }

    // ── Reconciliation Reports ────────────────────────────────
    match /reconciliationReports/{reportId} {
      allow read: if isAdmin();
      allow write: if false; // server-only
    }

    // ── Transactions ──────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isAuthenticated();
      allow write: if false; // server-only
    }

    // ── Contact Messages ──────────────────────────────────────
    match /contactMessages/{msgId} {
      allow read: if isAdmin() || 
        (isAuthenticated() && resource.data.user == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }
  }
}
